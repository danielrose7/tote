# Tote Environment Variables
# Copy this file to .env.local and fill in the values

# Jazz API Key (get from jazz.tools)
VITE_JAZZ_API_KEY=your_jazz_api_key
NEXT_PUBLIC_JAZZ_API_KEY=your_jazz_api_key

# Clerk Authentication (get from clerk.com dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Jazz Worker Account (for server-side operations)
JAZZ_WORKER_ACCOUNT=co_xxx
JAZZ_WORKER_SECRET=sealerSecret_xxx/signerSecret_xxx

# Chrome Extension ID (optional, for web app <-> extension communication)
# Get this from chrome://extensions/ after loading the unpacked extension
# Only needed if you want the web app to use the extension for metadata refresh
# NEXT_PUBLIC_EXTENSION_ID=abcdefghijklmnopqrstuvwxyz123456

# Brave Search API (for curator URL discovery)
BRAVE_SEARCH_API_KEY=BSA...

# Stripe (for curator credits billing)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx  # from `stripe listen` or Stripe Dashboard
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare R2 (for page capture corpus)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=tote-captures
