{
  "name": "tote-ios",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "ios:sync-overrides": "node ./scripts/sync-ios-overrides.mjs",
    "ios:check-overrides": "node ./scripts/check-ios-overrides.mjs",
    "start": "expo start --dev-client --localhost",
    "start:clear": "expo start --dev-client --localhost --clear",
    "start:lan": "expo start --dev-client --lan",
    "android": "expo run:android",
    "ios": "pnpm ios:sync-overrides && expo run:ios",
    "ios:sim-clean": "pnpm ios:sync-overrides && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 xcodebuild -workspace ios/Tote.xcworkspace -scheme Tote -configuration Debug -destination 'platform=iOS Simulator,name=iPhone 16 Pro' -derivedDataPath ios/build clean build",
    "web": "expo start --web"
  },
  "dependencies": {
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@bacons/text-decoder": "^0.0.0",
    "@clerk/expo": "^3.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "~55.0.8",
    "expo-auth-session": "^55.0.8",
    "expo-clipboard": "~55.0.9",
    "expo-crypto": "^55.0.9",
    "expo-file-system": "^55.0.10",
    "expo-secure-store": "^55.0.8",
    "expo-share-extension": "^5.0.6",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.9",
    "jazz-tools": "^0.19.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-dnd": "^2.0.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-webview": "^13.16.1",
    "react-native-worklets": "0.7.2",
    "readable-stream": "^4.7.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
